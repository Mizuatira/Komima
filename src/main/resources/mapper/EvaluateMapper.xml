<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.komima.mapper.EvaluateMapper">

    <resultMap id="EvaluateResultMap" type="com.komima.entity.Evaluate">
        <id column="id" property="id"/>
        <result column="task_id" property="taskId"/>
        <result column="from_user_id" property="fromUserId"/>
        <result column="to_user_id" property="toUserId"/>
        <result column="score" property="score"/>
        <result column="content" property="content"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO evaluate (task_id, from_user_id, to_user_id, score, content, create_time)
        VALUES (#{taskId}, #{fromUserId}, #{toUserId}, #{score}, #{content}, #{createTime})
    </insert>

    <select id="selectByTaskId" resultMap="EvaluateResultMap">
        SELECT * FROM evaluate WHERE task_id = #{taskId} ORDER BY create_time DESC
    </select>

    <select id="selectByUserId" resultMap="EvaluateResultMap">
        SELECT * FROM evaluate WHERE to_user_id = #{userId} ORDER BY create_time DESC
    </select>

    <select id="selectByTaskAndFromUser" resultMap="EvaluateResultMap">
        SELECT * FROM evaluate WHERE task_id = #{taskId} AND from_user_id = #{fromUserId}
    </select>

    <select id="selectAll" resultMap="EvaluateResultMap">
        SELECT * FROM evaluate ORDER BY create_time DESC
    </select>

    <delete id="deleteById">
        DELETE FROM evaluate WHERE id = #{id}
    </delete>
</mapper>
